# ========================================
# KONFIGURASI SMADER IoT Service
# ========================================

# URL Backend Server untuk mengirim signal
URL_SERVER=http://localhost:3000/api/signals

# Nomor Ruang / Ruangan yang terdeteksi
NOMOR_RUANG=102

# Cooldown dalam detik sebelum boleh mengirim signal lagi
# Mencegah duplicate request terlalu cepat
COOLDOWN_SECONDS=3

# Tampilkan UI video (True/False)
# Jika False, aplikasi berjalan di background (headless mode)
SHOW_UI=True

# Index kamera (0 untuk built-in/default camera)
CAMERA_INDEX=0

# ========================================
# KONTROL TRAFFIC & MONITORING (NEW)
# ========================================

# Maksimal request yang dapat ditampung dalam queue
# Jika lebih dari ini, request baru akan ditolak (mencegah overload)
MAX_QUEUE_SIZE=5

# Timeout untuk setiap HTTP request ke server (dalam detik)
# Jika server tidak respond dalam waktu ini, request akan dibatalkan
REQUEST_TIMEOUT=5

# ========================================
# TIPS KONFIGURASI
# ========================================
# 
# UNTUK DEVELOPMENT:
# - URL_SERVER=http://localhost:3000/api/signals
# - SHOW_UI=True
# - COOLDOWN_SECONDS=1
#
# UNTUK PRODUCTION:
# - URL_SERVER=http://192.168.x.x:3000/api/signals
# - SHOW_UI=False
# - COOLDOWN_SECONDS=3
# - MAX_QUEUE_SIZE=10
#
# UNTUK TESTING MULTIPLE CAMERAS:
# - CAMERA_INDEX=0 (camera pertama)
# - CAMERA_INDEX=1 (camera kedua)
# - dst...
#
